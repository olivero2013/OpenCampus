generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Student {
  id              Int      @id @default(autoincrement())
  firstname       String
  lastname        String
  preferredname   String?
  studentID       Int      @unique
  dateOfBirth     DateTime
  gender          String
  enrollment      Boolean

  schoolId        Int
  school          School   @relation(fields: [schoolId], references: [id])

  contacts        StudentContact[]
}

model School {
  id       Int       @id @default(autoincrement())
  name     String

  students Student[]
}

model Contact {
  id              Int      @id @default(autoincrement())

  firstname       String
  lastname        String
  preferredname   String?
  phoneNumber     String?
  email           String?

  students        StudentContact[]
}

model StudentContact {
  id                  Int      @id @default(autoincrement())

  studentId           Int
  contactId           Int

  relationship        String?

  emergencyContact    Boolean  @default(false)
  pickupAuthorized    Boolean  @default(false)
  receivesMailings    Boolean  @default(true)

  student             Student  @relation(fields: [studentId], references: [id])
  contact             Contact  @relation(fields: [contactId], references: [id])

  @@unique([studentId, contactId])
}