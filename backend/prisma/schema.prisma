generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Student {
  id              Int      @id @default(autoincrement())
  firstname       String
  lastname        String
  preferredname   String?
  studentID       Int      @unique
  dateOfBirth     DateTime
  gender          String
  enrollment      Boolean

  schoolId        Int
  school          School   @relation(fields: [schoolId], references: [id])

  contacts        StudentContact[]
}

model School {
  id       Int       @id @default(autoincrement())
  name     String

  students Student[]
}

model Contact {
  id              Int      @id @default(autoincrement())

  firstname       String
  lastname        String
  preferredname   String?

  phoneNumber     String?
  mobileNumber    String?
  workPhone       String?

  email           String?

  address1        String?
  address2        String?
  city            String?
  state           String?
  zipCode         String?

  employer        String?
  occupation      String?

  students        StudentContact[]
}

model StudentContact {
  id Int @id @default(autoincrement())

  studentId Int
  contactId Int

  relationship String

  emergencyContact Boolean @default(false)
  pickupAuthorized Boolean @default(false)

  primaryGuardian Boolean @default(false)

  receivesMailings Boolean @default(true)
  receivesReportCards Boolean @default(true)
  receivesAttendanceAlerts Boolean @default(true)
  receivesDisciplineAlerts Boolean @default(true)

  livesWithStudent Boolean @default(false)

  custodyRights Boolean @default(false)
  educationalRights Boolean @default(false)

  sortOrder Int @default(0)

  student Student @relation(fields: [studentId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([studentId, contactId])
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  passwordHash String
  tokenVersion Int           @default(1)

  createdAt    DateTime      @default(now())
  enabled      Boolean       @default(true)

  sessions     UserSession[]
  permissionGrants PermissionGrant[]
}

model UserSession {
  id               Int      @id @default(autoincrement())
  userId           Int
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime @updatedAt
  expiresAt        DateTime
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([revokedAt])
}

model PermissionGrant {
  id           Int    @id @default(autoincrement())
  userId       Int
  action       String
  resourcePath String
  allow        Boolean

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
}